generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String              @id @default(uuid())
  name               String
  plan               String              @default("free")
  status             String              @default("active")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  aiLogs             AiLog[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  billingUsages      BillingUsage[]
  bots               Bot[]
  conversations      Conversation[]
  events             Event[]
  leads              Lead[]
  messages           Message[]
  users              User[]
  workflows          Workflow[]
  workflowExecutions WorkflowExecution[]
}

model User {
  id            String           @id @default(uuid())
  clerkId       String?          @unique
  tenantId      String
  email         String           @unique
  passwordHash  String?
  role          String           @default("viewer")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  name          String?
  bots          Bot[]
  refreshTokens RefreshToken[]
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credentials   UserCredential[]

  @@index([tenantId])
  @@index([clerkId])
}

model Bot {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  displayName String
  platform    String
  sessionName String?  @unique
  status      String   @default("active")
  config      Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
  leads       Lead[]

  @@index([tenantId])
  @@index([userId])
}

model Lead {
  id                 String              @id @default(uuid())
  tenantId           String
  botId              String?
  name               String?
  phone              String?
  email              String?
  source             String?
  status             String              @default("new")
  attributes         Json?               @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  botPaused          Boolean             @default(false)
  conversations      Conversation[]
  bot                Bot?                @relation(fields: [botId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowExecutions WorkflowExecution[]

  @@index([tenantId])
  @@index([botId])
}

model Conversation {
  id             String    @id @default(uuid())
  tenantId       String
  leadId         String
  platform       String
  externalUserId String
  status         String    @default("open")
  lastMessageAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  healthScore    Int       @default(100)
  intent         String?
  lead           Lead      @relation(fields: [leadId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([tenantId])
  @@index([leadId])
}

model Message {
  id                String       @id @default(uuid())
  tenantId          String
  conversationId    String
  direction         String
  content           String?
  messageType       String       @default("text")
  platformMessageId String?
  metadata          Json?        @default("{}")
  createdAt         DateTime     @default(now())
  status            String       @default("pending")
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([platformMessageId])
}

model Workflow {
  id            String              @id @default(uuid())
  tenantId      String
  name          String
  triggerIntent String
  steps         Json                @default("[]")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions    WorkflowExecution[]

  @@index([tenantId])
}

model WorkflowExecution {
  id               String   @id @default(uuid())
  tenantId         String
  workflowId       String
  leadId           String
  currentStepIndex Int      @default(0)
  status           String   @default("active")
  collectedData    Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lead             Lead     @relation(fields: [leadId], references: [id])
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow         Workflow @relation(fields: [workflowId], references: [id])

  @@index([tenantId])
  @@index([leadId])
}

model ApiKey {
  id        String   @id @default(uuid())
  tenantId  String
  keyHash   String   @unique
  name      String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Event {
  id        String   @id @default(uuid())
  tenantId  String
  type      String
  payload   Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model BillingUsage {
  id          String   @id @default(uuid())
  tenantId    String
  metric      String
  quantity    BigInt
  periodStart DateTime
  periodEnd   DateTime
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metric, periodStart])
  @@index([tenantId])
}

model AiLog {
  id               String   @id @default(uuid())
  tenantId         String
  model            String
  promptTokens     Int
  completionTokens Int
  cost             Decimal?
  metadata         Json?
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  action    String
  actorId   String?
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model UserCredential {
  id        String   @id @default(uuid())
  userId    String
  provider  String
  keyName   String
  keyValue  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, provider, keyName])
  @@index([userId])
}
